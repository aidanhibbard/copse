{
  "name": "@aidanhibbard/copse",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "npm@10.9.2",
  "description": "Git worktree manager — create worktrees and open editors for parallel development",
  "author": "aidanhibbard",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aidanhibbard/copse.git"
  },
  "keywords": [
    "git",
    "worktree",
    "cli",
    "cursor",
    "vscode",
    "editor"
  ],
  "bin": {
    "copse": "dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "obuild ./src/index.ts",
    "dev": "vitest dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "release": "npm run spec && npm run build && npm publish --access public && git push --follow-tags",
    "spec": "npm run lint && npm run spec:types && npm run spec:coverage && npm run build",
    "spec:coverage": "vitest run --coverage",
    "spec:types": "tsc --noEmit --skipLibCheck",
    "prepublishOnly": "npm run build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "citty": "^0.2.1",
    "consola": "^3.4.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.2",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.22.0",
    "jiti": "^2.6.1",
    "obuild": "^0.4.31",
    "typescript": "^5.8.2",
    "vitepress": "^1.6.3",
    "vitest": "^4.1.0"
  }
}
